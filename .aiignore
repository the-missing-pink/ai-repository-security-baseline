# =============================================================================
# Universal AI Agent Ignore File
# =============================================================================
# This file defines patterns that ALL AI agents should respect.
# Tool-specific ignore files (.cursorignore, .clineignore, .aiderignore)
# reference these same patterns.
#
# Files matching these patterns should NOT be read, indexed, or included
# in AI agent context unless the user explicitly requests it.
# =============================================================================

# ---------------------------------------------------------------------------
# Environment & Secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template
.env.local
.env.development.local
.env.test.local
.env.production.local

# ---------------------------------------------------------------------------
# Cryptographic Keys & Certificates
# ---------------------------------------------------------------------------
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
*.jks
*.keystore
*.truststore
id_rsa
id_ed25519
id_ecdsa
*.pub

# ---------------------------------------------------------------------------
# Credential Files
# ---------------------------------------------------------------------------
credentials.json
service-account*.json
*-credentials.json
*-secret.json
token.json
secrets.yml
secrets.yaml
vault.yml
vault.yaml
.htpasswd
.netrc
.npmrc
.pypirc
pip.conf

# ---------------------------------------------------------------------------
# Cloud Provider Credentials
# ---------------------------------------------------------------------------
.aws/
.azure/
.config/gcloud/
.kube/config
kubeconfig*

# ---------------------------------------------------------------------------
# SSH
# ---------------------------------------------------------------------------
.ssh/

# ---------------------------------------------------------------------------
# Git Internals
# ---------------------------------------------------------------------------
.git/

# ---------------------------------------------------------------------------
# Infrastructure State (may contain secrets)
# ---------------------------------------------------------------------------
terraform.tfstate
terraform.tfstate.backup
*.tfvars
.terraform/

# ---------------------------------------------------------------------------
# IDE & Editor Local State (may contain tokens)
# ---------------------------------------------------------------------------
.idea/
.vscode/settings.json
.vscode/launch.json

# ---------------------------------------------------------------------------
# Build Artifacts & Dependencies (noise reduction)
# ---------------------------------------------------------------------------
node_modules/
__pycache__/
*.pyc
.tox/
.venv/
venv/
dist/
build/
*.egg-info/
target/
.gradle/
.maven/

# ---------------------------------------------------------------------------
# OS Files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ---------------------------------------------------------------------------
# Log Files (may contain sensitive data)
# ---------------------------------------------------------------------------
*.log
logs/

# ---------------------------------------------------------------------------
# Database Files
# ---------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db

# ---------------------------------------------------------------------------
# Backup Files
# ---------------------------------------------------------------------------
*.bak
*.backup
*.old
*.orig
*.swp
*~
